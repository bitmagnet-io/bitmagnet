  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run bitmagnet backend",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "args": ["start"]
    },
    {
      "name": "Run bitmagnet web UI",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/webui",
      "program": "npm",
      "args": ["start"]
    }
  ]
}
