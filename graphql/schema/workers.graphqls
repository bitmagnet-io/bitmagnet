type Worker {
  ref: Ref!
  label: String!
  state: WorkerState!
  error: String
  requiredBy: [Ref!]!
  dependsOn: [Ref!]!
}

type WorkerListAllQueryResult {
  workers: [Worker!]!
}

type WorkerQuery {
  listAll: WorkerListAllQueryResult!
}

type WorkerMutation {
  start(refs: [Ref!]!): WorkerListAllQueryResult!
  shutdown(refs: [Ref!]!): WorkerListAllQueryResult!
  restart(refs: [Ref!]!): WorkerListAllQueryResult!
}
