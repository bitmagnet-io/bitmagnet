type PluginQuery {
  list: [PluginInfo!]!
}

type PluginInfo {
  ref: Ref!
  enabled: Boolean!
  dependsOn: [Ref!]!
  requiredBy: [Ref!]!
  localizedContent: PluginLocalizedContent!
}

type PluginLocalizedContent {
  description: String
  configParams: [ConfigParamLocalizedContent!]!
}

type ConfigParamLocalizedContent {
  ref: Ref!
  description: String!
}
