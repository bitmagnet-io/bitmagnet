    "apollo-angular": "^11.0.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "filesize": "^11.0.13",
    "graphql": "^16.12.0",
    "ng2-charts": "^8.0.0",
    "picomatch": "^4.0.3",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
